# ─────────────────────────────────────────────────────────────────────────────
#  SolveWatch AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  All three services (Node.js, Python transcriber, Electron) read this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports & Paths ─────────────────────────────────────────────────────────────

# Node.js backend HTTP port (default: 4000)
PORT=4000

# Absolute path to the folder monitored for new screenshots
SCREENSHOTS_PATH=

# Electron HUD connects to Node on this URL
SOCKET_URL=http://localhost:4000

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# At least one key is required. Providers without keys are skipped in the
# fallback chain. Keys are never logged or exposed in the settings UI.

# OpenAI — GPT-4o-mini (default), Whisper API (when STT_MODEL=whisper-1)
OPENAI_API_KEY=

# Groq — llama-3.3-70b-versatile (default)
GROQ_API_KEY=

# Google Gemini — gemini-2.5-flash (default)
GEMINI_API_KEY=

# Anthropic Claude — claude-sonnet-4-5 (default)
ANTHROPIC_API_KEY=

# ── AI Provider Config ────────────────────────────────────────────────────────

# Fallback order: comma-separated list of provider IDs
# When the first provider fails, the next one is tried automatically
PROVIDER_ORDER=openai,grok,gemini,claude

# Active providers: comma-separated (must be a subset of PROVIDER_ORDER)
PROVIDER_ENABLED=openai

# Per-provider model selection
MODEL_OPENAI=gpt-4o-mini
MODEL_GROK=llama-3.3-70b-versatile
MODEL_GEMINI=gemini-2.5-flash
MODEL_CLAUDE=claude-sonnet-4-5

# Ollama local LLM — used for question classification and conversation summarization only
# Default model is fast (1.3 GB). Run: ollama pull llama3.2:1b
OLLAMA_MODEL=llama3.2:1b

# Whether Ollama is enabled as a fallback (true/false)
OLLAMA_ENABLED=true

# Answer routing: auto | openai | grok | gemini | claude | ollama
# "auto" = use the first working provider in PROVIDER_ORDER
ANSWER_MODE=auto

# Interview context injected into all prompts (e.g. "backend engineer", "iOS developer")
INTERVIEW_ROLE=

# ── STT (Speech-to-Text) ──────────────────────────────────────────────────────

# Local Whisper model: tiny | base | small | medium | large
# Use "whisper-1" for OpenAI Whisper API (requires OPENAI_API_KEY)
# Set to "deepgram" to use Deepgram cloud STT (requires DEEPGRAM_ENABLED=true)
STT_MODEL=small

# Whisper backend: mlx (Apple Silicon GPU) | local (CPU) | api (OpenAI)
# Leave empty for auto-detection: Apple Silicon → mlx, everything else → local
WHISPER_BACKEND=

# ── Deepgram Cloud STT ────────────────────────────────────────────────────────
# Deepgram replaces local Whisper when enabled. Much lower latency (~300ms vs
# 1-3s) with live word-by-word streaming to the HUD.
# Get your key at: console.deepgram.com — $200 free credit on sign-up

# Enable Deepgram (true/false)
DEEPGRAM_ENABLED=false

# Your Deepgram API key
DEEPGRAM_API_KEY=

# Transcription model: nova-2 (best) | nova | enhanced | base
DEEPGRAM_MODEL=nova-2

# Transcription language code (e.g. en, es, fr)
DEEPGRAM_LANGUAGE=en

# Audio encoding — do not change
DEEPGRAM_ENCODING=linear16

# Audio sample rate in Hz — do not change
DEEPGRAM_SAMPLE_RATE=16000

# Silence in milliseconds before speech_final fires (min: 10ms, recommended: 300ms)
# Lower = faster response but may cut off mid-sentence pauses
DEEPGRAM_ENDPOINTING_MS=300

# Fallback timeout: ms of no new words before treating utterance as done (min: 1000ms)
# Fires when background noise prevents acoustic silence detection
DEEPGRAM_UTTERANCE_END_MS=1000

# Diarize (identify speakers): true | false
# When true, your voice is filtered out — only the interviewer reaches AI
DEEPGRAM_DIARIZE=true

# Auto-format numbers, dates, punctuation (true/false)
DEEPGRAM_SMART_FORMAT=true

# Stream partial transcripts to HUD live strip while speaking (true/false)
DEEPGRAM_INTERIM_RESULTS=true

# Discard utterances shorter than this many words (prevents noise/filler from reaching AI)
DEEPGRAM_MIN_WORD_COUNT=2

# Auto-enrollment: seconds of speech to capture when listener first starts
# Your voice is identified and excluded; interviewer's speech passes to AI
# Set to 0 to disable auto-enrollment (requires manual enrollment via settings)
DEEPGRAM_ENROLL_SECONDS=5

# ── VAD — Voice Activity Detection (Whisper/local STT path only) ──────────────
# These settings are ignored when DEEPGRAM_ENABLED=true

# VAD engine: silero (neural, recommended) | webrtc | energy (simple threshold)
VAD_ENGINE=silero

# RMS energy floor before Silero runs — cheap pre-filter
# Lower = more sensitive to quiet speech; raise if background noise triggers VAD
VAD_ENERGY_GATE_THRESHOLD=0.015

# Fraction of audio frames in a window that must be speech to count as speech
VAD_SPEECH_FRAME_RATIO=0.45

# Ignore speech bursts shorter than this (seconds)
VAD_MIN_SPEECH_DURATION=0.5

# Seconds of VAD-silence before flushing audio buffer to Whisper
# Lower = faster response; too low = cuts off mid-pause pauses
VAD_SILENCE_THRESHOLD=0.3

# Force-flush after this many seconds even if VAD never detects silence (prevents hangs)
VAD_MAX_UTTERANCE_DURATION=30

# Whisper output: discard transcripts shorter than this many words
VAD_MIN_WORD_COUNT=5

# Silero neural VAD confidence threshold (0.0–1.0)
# Higher = stricter; 0.7 filters most background noise without missing quiet speech
VAD_SILERO_THRESHOLD=0.7

# Ignore speech segments shorter than this (ms) — filters clicks and pops
VAD_SILERO_MIN_SPEECH_MS=100

# Silence must last at least this long to be counted (ms)
VAD_SILERO_MIN_SILENCE_MS=250

# ── Speaker Identification (Whisper path only) ────────────────────────────────
# Uses SpeechBrain ECAPA-TDNN to identify your voice and filter it out.
# Ignored when DEEPGRAM_ENABLED=true (Deepgram has its own diarization).

# Enable speaker identification (true/false)
SPEAKER_ID_ENABLED=true

# Cosine similarity threshold (0.0–1.0)
# Raise toward 0.80 if your voice leaks through; lower toward 0.55 if interviewer is blocked
SPEAKER_ID_THRESHOLD=0.6

# ── HUD Appearance ────────────────────────────────────────────────────────────

# Overlay opacity (0 = fully opaque, 100 = invisible; default: 27)
HUD_OPACITY=27

# Start the always-on listener automatically when the app launches (true/false)
ALWAYS_ON_ENABLED=false

# ── Telemetry (Grafana Cloud OTLP) ───────────────────────────────────────────
# Structured metrics and logs exported to Grafana Cloud.
# All disabled by default — enable via the settings page.
# Get credentials at: grafana.com → My Account → Stack → OTel configuration

# Enable telemetry export (true/false)
TELEMETRY_ENABLED=false

# OTLP HTTP endpoint from your Grafana Cloud stack
OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# Grafana Cloud instance ID (numeric, shown in the OTLP configuration page)
GRAFANA_INSTANCE_ID=

# Grafana Cloud access policy token (metrics:write + logs:write scopes required)
GRAFANA_ACCESS_TOKEN=

# Metrics/logs service name prefix (appears as a label in Grafana)
TELEMETRY_SERVICE_PREFIX=solvewatch

# Your name or machine label (appears in Grafana dashboards for multi-machine setups)
HOST_OWNER=

# Grafana instance URL for dashboard auto-import (e.g. https://my-stack.grafana.net)
GRAFANA_URL=

# Grafana Service Account token for dashboard import (Editor role + dashboards:write)
GRAFANA_SA_TOKEN=
