          "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
        },
        {
          "id": 34, "type": "stat", "title": "OCR failures",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 4, "w": 8, "x": 8, "y": 67 },
          "targets": [{ "refId": "A", "expr": "sum(increase(ocr_failed_total[$__range]))" }],
          "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }
          ]}}},
          "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
        },
