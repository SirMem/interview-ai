          "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }
          ]}}},
          "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
