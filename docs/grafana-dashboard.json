          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 73 },
          "targets": [
            { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(silence_wait_actual_ms_bucket[$__rate_interval])))", "legendFormat": "P50" },
            { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(silence_wait_actual_ms_bucket[$__rate_interval])))", "legendFormat": "P95" }
          ],
          "fieldConfig": { "defaults": { "unit": "ms" } }
        }
      ]
    },

    {
      "id": 102, "type": "row", "title": "AI cost & tokens (expand to view)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 }, "collapsed": true,
      "panels": [
        {
          "id": 41, "type": "timeseries", "title": "$ rate by provider",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
          "targets": [{ "refId": "A", "expr": "sum by (provider) (rate(ai_cost_usd_total{provider=~\"$provider\", flow=~\"$flow\"}[$__rate_interval]))", "legendFormat": "{{provider}}" }],
          "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 6, "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } } } }
        },
        {
          "id": 42, "type": "timeseries", "title": "Tokens in/out by model",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
          "targets": [
            { "refId": "A", "expr": "sum by (model) (rate(ai_input_tokens_total{provider=~\"$provider\", flow=~\"$flow\"}[$__rate_interval]))",  "legendFormat": "in: {{model}}" },
            { "refId": "B", "expr": "sum by (model) (rate(ai_output_tokens_total{provider=~\"$provider\", flow=~\"$flow\"}[$__rate_interval]))", "legendFormat": "out: {{model}}" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
        },
        {
          "id": 6, "type": "stat", "title": "Cost per question",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 66 },
          "targets": [{ "refId": "A", "expr": "sum(increase(ai_cost_usd_total[$__range])) / clamp_min(sum(increase(utterances_passed_total[$__range])), 1)" }],
          "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 5, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 0.005 }, { "color": "red", "value": 0.05 }
          ]}}},
          "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
        },
        {
          "id": 2, "type": "stat", "title": "Spend forecast (30 days)",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 4, "w": 6, "x": 6, "y": 66 },
          "targets": [{ "refId": "A", "expr": "sum(rate(ai_cost_usd_total[1h])) * 86400 * 30" }],
          "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 25 }, { "color": "red", "value": 100 }
          ]}}},
          "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
        },
        {
          "id": 44, "type": "piechart", "title": "Output-token share by provider",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 8, "w": 6, "x": 12, "y": 66 },
          "targets": [{ "refId": "A", "expr": "sum by (provider) (increase(ai_output_tokens_total[$__range]))", "legendFormat": "{{provider}}" }],
          "options": { "pieType": "donut", "displayLabels": ["name", "percent"], "legend": { "displayMode": "list", "placement": "right" } }
        },
        {
          "id": 45, "type": "stat", "title": "Local vs paid (output tokens)",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 8, "w": 6, "x": 18, "y": 66 },
          "targets": [
            { "refId": "A", "expr": "sum(increase(ai_output_tokens_total{provider=\"ollama\"}[$__range]))",  "legendFormat": "local (ollama)" },
            { "refId": "B", "expr": "sum(increase(ai_output_tokens_total{provider!=\"ollama\"}[$__range]))", "legendFormat": "paid (cloud)" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
          "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" }
        },
        {
          "id": 46, "type": "stat", "title": "Anthropic cache hit ratio",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 74 },
          "targets": [{ "refId": "A", "expr": "100 * sum(increase(ai_cache_read_tokens_total[$__range])) / clamp_min(sum(increase(ai_input_tokens_total{provider=\"claude\"}[$__range])) + sum(increase(ai_cache_read_tokens_total[$__range])) + sum(increase(ai_cache_creation_tokens_total[$__range])), 1)" }],
          "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 70 }
          ]}}},
          "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
        },
        {
          "id": 47, "type": "timeseries", "title": "Anthropic cache reads vs creations vs uncached input (rate)",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "gridPos": { "h": 4, "w": 18, "x": 6, "y": 74 },
          "targets": [
            { "refId": "A", "expr": "sum(rate(ai_cache_read_tokens_total[$__rate_interval]))",                       "legendFormat": "cache hit (cheap)" },
            { "refId": "B", "expr": "sum(rate(ai_cache_creation_tokens_total[$__rate_interval]))",                   "legendFormat": "cache write (expensive)" },
            { "refId": "C", "expr": "sum(rate(ai_input_tokens_total{provider=\"claude\"}[$__rate_interval]))",       "legendFormat": "uncached input" }
          ],
          "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
        }
      ]
    },

